; Fire Gun Shooting
; This code is based on N64Mario's SSBMario and Cable's Gun Fire
; You can shooting fire 2 times,Also You can moving projectile's coordinate
; It's good when you doing Chain Combos! ~FelixMario2011
[Statedef 1006]
type    = S
movetype= A
physics = S
juggle  = 4
