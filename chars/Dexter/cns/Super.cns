;---------------------------------------------------------------------------
; Ray Gun (Probably based on Cartoon Network punch time explosion)
; This code is based on N64Mario's SSBMario and aperson98's Stimpy edit
; You can holding "X" for Ray Gun Charge in air and ground
; Even if you fall from the air on the ground, you still can Charging.
; isn't cool, hum? ~FelixMario2011
[Statedef 1000]
type    = A
movetype= A
physics = N
poweradd= 100
anim = 1000
ctrl = 0
sprpriority = 1

[State 1000,Effect]
type = PlaySnd
trigger1 = AnimElem = 1
value = s1000, 1

[State 1000,StateType]
type = StateTypeSet
trigger1 = Pos Y = 0
statetype = S

[State 1000,StateType]
type = StateTypeSet
trigger1 = Pos Y != 0
statetype = A

[State 1000,Anim]
type = ChangeAnim
trigger1 = Anim != 1000
trigger1 = StateType != A
value = 1000
elem = AnimElemNo(0)

[State 1000,Anim]
type = ChangeAnim
trigger1 = Anim != 1100
trigger1 = StateType = A
value = 1100
elem = AnimElemNo(0)

[State 1000,Veladd]
type = VelAdd
trigger1 = StateType = A
y = .44

[State 1000,VelSet]
type = VelSet
trigger1 = Pos Y >= -0
trigger1 = Vel Y >= 0
y = 0

[State 1000,PosSet]
type = PosSet
trigger1 = Pos Y >= -0
trigger1 = Vel Y >= 0
y = 0

[State 1000,VelSet]
type = VelSet
trigger1 = Pos Y >= -0
x = 0

[State 1000,Width];With Ray Gun's Width
type = Width
trigger1 = 1
edge = 0,0
player = 30,20

[State 1000,Hold it!]
type = ChangeState
trigger1 = command = "Ray_Gun_hold"
value = 1001
ctrl = 0

[State 1000,Take that!]
type = ChangeState
trigger1 = command != "Ray_Gun_hold"
value = 1002
ctrl = 0
;---------------------------------------------------------------------------
; Ray Gun charge!
[Statedef 1001]
type    = A
movetype= A
physics = N
poweradd= 0
anim = 1000
ctrl = 0

[State 1001,Effect]
type = PlaySnd
trigger1 = time = 0
value = s900, 2

[State 1001,Effect]
type = PlaySnd
trigger1 = time = 0
value = S900,0
channel = 5
loop = 1

[State 1001,StateType]
type = StateTypeSet
trigger1 = Pos Y = 0
statetype = S

[State 1001,StateType]
type = StateTypeSet
trigger1 = Pos Y != 0
statetype = A

[State 1001,Anim]
type = ChangeAnim
trigger1 = Anim != 1000
trigger1 = StateType != A
value = 1000
elem = AnimElemNo(0)

[State 1001,Anim]
type = ChangeAnim
trigger1 = Anim != 1100
trigger1 = StateType = A
value = 1100
elem = AnimElemNo(0)

[State 1001,Veladd]
type = VelAdd
trigger1 = StateType = A
y = .44

[State 1001,VelSet]
type = VelSet
trigger1 = Pos Y >= -0
trigger1 = Vel Y >= 0
y = 0

[State 1001,PosSet]
type = PosSet
trigger1 = Pos Y >= -0
trigger1 = Vel Y >= 0
y = 0

[State 1001,VelSet]
type = VelSet
trigger1 = Pos Y >= -0
x = 0

[State 1001,Width];Still With Ray Gun's Width!
type = Width
trigger1 = 1
edge = 0,0
player = 30,20

[State 1001,7];Weak, When you would like to do chain combos.
type = ChangeState
trigger1 = command != "Ray_Gun_hold" && time = [0,10]
value = 1002
ctrl = 0

[State 1001,7];Just medium, meh!
type = ChangeState
trigger1 = command != "Ray_Gun_hold" && time = [11,20]
value = 1003
ctrl = 0

[State 1001,7];Almost close!
type = ChangeState
trigger1 = command != "Ray_Gun_hold" && time = [21,30]
value = 1004
ctrl = 0

[State 1001,PalFX]
type = PalFX
trigger1 = time = 5
trigger2 = time = 10
trigger3 = time = 15
trigger4 = time = 20
trigger5 = time = 25
trigger6 = time = 30
trigger7 = time = 35
trigger8 = time = 40
trigger9 = time = 45
time = 5
add = 30,30,60
sinadd = 50,50,50,4

[State 1001,Ray Spark Explod]
type = explod
trigger1 = AnimElem = 2
trigger1 = NumExplod(1000) = 0
ID = 1000
anim = 1003
postype = p1
sprpriority = 3
pos = 60,-21
ownpal = 1
bindtime = -1
removetime = -1
removeongethit = 1
scale = .4,.4

[State 1001,Electric Charge Explod]
type = explod
trigger1 = AnimElem = 2
trigger1 = NumExplod(1001) = 0
ID = 1001
anim = 1007
postype = p1
sprpriority = 4
pos = 57,-21
ownpal = 1
bindtime = -1
removetime = -1
removeongethit = 1
scale = .3,.3

[State 1001, End];Faster and more lethal!
type = ChangeState
trigger1 = time = 40
value = 1005
ctrl = 0
