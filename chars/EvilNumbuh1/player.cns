type = AssertSpecial
trigger1 = 1
flag = noairguard
flag2 = nocrouchguard
flag3 = nostandguard

[State 101, VelSet]
type = VelSet
trigger1 = time = 0
x = 6

[State 101, 2] ;Prevent run from canceling into walk
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 101, 3] ;Prevent from turning
type = AssertSpecial
trigger1 = 1
flag = NoAutoTurn

[State 100, 4]
type = ChangeState
trigger1 = command = "holdup"
value = 40

[State 101, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S101,0
channel = -1

[State 101, End]
type = ChangeState
trigger1 = animtime = 0
value = 0
ctrl = 1

;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1
facep2 = 1

[State 40, Jump Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = prevstateno != 100
trigger1 = prevstateno != 105
value = 41,0

[State 40, Run Jump Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = prevstateno = 100
trigger2 = prevstateno = 105
value = 41,2

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = prevstateno = 105 ;RUN_BACK
trigger1 = sysvar(1) = -1
x = const(velocity.runjump.back.x)

[State 40, 6]
type = ChangeState
triggerall = AnimTime = 0
triggerall = prevstateno = 105 || prevstateno = 100
trigger1 = command = "holdback"
value = 106
ctrl = 1

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; AirJump Start
[Statedef 45]
type    = A
physics = N
ctrl = 0
velset = 0,0

[State 45, Air Jump Sound]
type = PlaySnd
trigger1 = time = 0
value = S41,1

[State 45, ChangeAnim]
type = ChangeAnim
trigger1 = time = 0
value = 47

[State 45, 2]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 45, 3]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45, 4]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45, 5]
type = VelSet
trigger1 = Time = 2
x = ifelse(sysvar(1)=0, const(velocity.airjump.neu.x), ifelse(sysvar(1)=1, const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y = const(velocity.airjump.y)

[State 45, 6]
type = Explod
trigger1 = time = 0
anim = f120
pos = 0,0
postype = p1

[State 45, 7]
type = ChangeState
trigger1 = Time = 2
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 50, VelAdd]
type = VelAdd
trigger1 = time >= 1
trigger1 = command = "holdfwd"
x = 0.1

[State 50, VelAdd]
type = VelAdd
trigger1 = time >= 1
trigger1 = command = "holdback"
x = -0.1

[State 50, 0]
type = VarSet
trigger1 = time = 0
v = 2
value = 0

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))

[State 50, 3]
type = ChangeAnim
trigger1 = Vel y > Const720p(-8)
trigger1 = SelfAnimExist(anim + 3)
trigger1 = anim >= 41 && anim <= 43
persistent = 0
value = Anim + 3

[State 50, 4]
type = ChangeAnim
trigger1 = time = 0
trigger1 = prevstateno = 45
trigger1 = anim != 48
value = 48

[State 0, VelAdd]
type = VelAdd
trigger1 = time > 5
trigger1 = timemod = 2, 0
y = .2

;---------------------------------------------------------------------------
; Jump Land M.U.G.E.N. From 1.0
[Statedef 52]
type    = S
physics = S
ctrl = 0
anim = 47

[State 52, Dust]
type = Explod
trigger1 = !time
anim = 7104
ID = 7104
sprpriority = -2
postype = p1
scale = 0.5,0.5
ownpal = 1
pausemovetime = -1
supermovetime = -1

[State 52, 1]
type = VelSet
trigger1 = Time = 0
y = 0

[State 52, 2]
type = PosSet
trigger1 = Time = 0
y = 0

[State 52, 3]
type = CtrlSet
trigger1 = Time = 1
value = 1

[State 52, 4]
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
x = 0

[State 52, 5]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1

;---------------------------------------------------------------------------
; Override common states (use same number to override) :
;---------------------------------------------------------------------------

;---------------------------------------------------------------------------
; States that are always executed (use statedef -2)
;---------------------------------------------------------------------------
[Statedef -2]

[State -2, WinQuoteSet]
type = VictoryQuote
trigger1 = 1
value = 1+(random%7)

[State -2, WinQuoteSet]
type = VictoryQuote
triggerall = numenemy
trigger1 = enemy,Name = "Hoagie P. Gilligan, Jr." || enemy,Name = "Kids Next Door - Hoagie P. Gilligan, Jr." 
trigger2 = enemy,Name = "Kuki Sanban"
trigger3 = enemy,Name = "Wallabee Beetles"
trigger4 = enemy,Name = "Abigail Lincoln" || enemy,Name = "Kids Next Door - Abigail Lincoln" 
value = 50

[State -2, WinQuoteSet]
type = VictoryQuote
triggerall = numenemy
trigger1 = enemy,authorname = "DarkMasao2/Arcadboy" && enemy,Name = "Numbuh 1"
value = 51

[State -2, Super finish style 1]
type = Explod
triggerall = Win && !WinTime
triggerall = NumExplod(13580) = 0
trigger1 = StateNo = [2000,2999]
trigger2 = StateNo = [3000,3999]
anim = F 40
ID = 13580
sprpriority = -3
postype = left
pos = -30,10
bindtime = -1
supermove = 1
ownpal = 1
removetime = 160
scale = 1,1.2

[State -2,AssertSpecial]
type = AssertSpecial
triggerall = 1
trigger1 = NumExplod(13580) = 1
flag = NoBarDisplay
flag2 = NoBG
flag3 = NoFG
ignorehitpause = 1
;---------------------------------------------------------------------------
; States that are executed when in self's state file (use statedef -3)
;---------------------------------------------------------------------------

[Statedef -3]

[State -3, 2]
type = PlaySnd
triggerall = Time = 1
triggerall = Life
triggerall = random % 10 > 5
trigger1 = stateno = 5000 || stateno = 5020
trigger1 = anim != 5000 && anim != 5010
trigger2 = stateno = 5010
trigger2 = anim != 5020
value = 5000,0+Random%2
channel = 0
ignorehitpause = 1
volume = 255

;This controller plays a sound everytime the player lands from a jump, or
;from a back-dash.
[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = 40, 0
